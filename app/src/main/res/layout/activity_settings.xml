<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#9C27B0"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="返回" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:paddingStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="显示设置"
                android:textColor="#9C27B0"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="夜间模式"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/sw_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="隐藏状态栏（双击屏幕可临时切换）"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/sw_hide_statusbar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="缓存设置"
                android:textColor="#9C27B0"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清理页面缓存"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_cache_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击立即清理 WebView 页面缓存"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清理" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="阅读设置"
                android:textColor="#9C27B0"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="显示页码"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="在漫画阅读器底部显示当前页码"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Switch
                    android:id="@+id/sw_show_page_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="网络设置"
                android:textColor="#9C27B0"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="重新检测最快服务器"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_active_url"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前：检测中…"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_probe_url"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="手动选择服务器"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_source_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="检测仅按主页延迟排序；挡位由你手动决定"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_choose_url"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加载挡位"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_profile_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="normal 更快；conservative 更稳，适合慢源或卡顿时手动切换"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_choose_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="切换" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
