<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FF6200EE"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="返回" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:paddingStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- 显示设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="显示设置"
                android:textColor="#FF6200EE"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="夜间模式"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/sw_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="隐藏状态栏"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/sw_hide_statusbar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="顶部额外偏移（异形屏适配）"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_top_offset_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0dp"
                        android:textSize="14sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/sb_top_offset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100" />
            </LinearLayout>

            <!-- 缓存设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="缓存设置"
                android:textColor="#FF6200EE"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="开启页面缓存"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关闭后每次重新加载页面"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Switch
                    android:id="@+id/sw_enable_cache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清理页面缓存"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_cache_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击立即清理"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清理" />
            </LinearLayout>

            <!-- 阅读设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="阅读设置"
                android:textColor="#FF6200EE"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="显示页码"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="在漫画阅读器底部显示当前页码"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <Switch
                    android:id="@+id/sw_show_page_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="漫画页间距"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_manga_spacing_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0dp"
                        android:textSize="14sp"
                        android:textColor="#888888" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/sb_manga_spacing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="40" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
